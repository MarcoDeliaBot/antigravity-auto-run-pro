{
    "name": "antigravity-auto-run-pro",
    "displayName": "Antigravity Auto Run Pro",
    "description": "Seamlessly accept all Antigravity agent steps and terminal commands without limits.",
    "keywords": [
        "antigravity",
        "auto run command",
        "auto pilot",
        "auto accept",
        "free auto accept agent",
        "automation"
    ],
    "version": "1.6.4",
    "icon": "icon.png",
    "publisher": "marcodelia",
    "author": "Marco D'Elia",
    "repository": {
        "type": "git",
        "url": "https://github.com/MarcoDeliaBot/antigravity-auto-run-pro.git"
    },
    "engines": {
        "vscode": "^1.63.0"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./extension.js",
    "categories": [
        "Other"
    ],
    "dependencies": {
        "ws": "^8.13.0"
    },
    "contributes": {
        "commands": [
            {
                "command": "autorunpro.toggle",
                "title": "Toggle Auto Run Pro"
            },
            {
                "command": "autorunpro.toggleGodMode",
                "title": "Toggle God Mode (Auto Run Pro)"
            },
            {
                "command": "autorunpro.openLog",
                "title": "AntiGravity Auto Run Pro: Open Log File"
            }
        ],
        "keybindings": [
            {
                "command": "autorunpro.toggle",
                "key": "ctrl+alt+shift+r",
                "mac": "cmd+alt+shift+r"
            },
            {
                "command": "autorunpro.toggleGodMode",
                "key": "ctrl+alt+shift+g",
                "mac": "cmd+alt+shift+g"
            }
        ],
        "configuration": {
            "title": "Antigravity Auto Run Pro",
            "properties": {
                "autorunpro.godMode": {
                    "type": "boolean",
                    "default": false,
                    "description": "⚠️ God Mode: auto-accept parent folder access prompts (Allow, Always Allow, Consenti). DISABLED by default for safety — enabling this lets the agent access files outside your workspace without confirmation."
                },
                "autorunpro.antiLoopProtection": {
                    "type": "boolean",
                    "default": true,
                    "description": "Anti-loop protection: puts the extension in STANDBY if the same button is clicked repeatedly without success. Resumes automatically when the UI changes (e.g., when a new prompt is generated)."
                },
                "autorunpro.pollInterval": {
                    "type": "number",
                    "default": 500,
                    "description": "Polling interval in milliseconds for auto-accept checks."
                },
                "autorunpro.customButtonTexts": {
                    "type": "array",
                    "default": [],
                    "items": {
                        "type": "string"
                    },
                    "description": "Additional button texts to auto-click in the agent panel."
                }
            }
        }
    }
}